+# The OSS export currently omits these workspaces while bun.lock still contains
+# them. Create minimal manifests matching the lockfile so frozen installs remain
+# reproducible without modifying upstream Dockerfile.server directly.
+RUN mkdir -p packages/craft-agents-commands packages/craft-cli apps/marketing && \
+    printf '%s\n' \
+      '{' \
+      '  "name": "@craft-agent/craft-agents-commands",' \
+      '  "version": "0.10.2",' \
+      '  "dependencies": {' \
+      '    "@craft-agent/shared": "workspace:*"' \
+      '  },' \
+      '  "devDependencies": {' \
+      '    "@types/bun": "latest",' \
+      '    "@types/node": "^25.0.8"' \
+      '  }' \
+      '}' > packages/craft-agents-commands/package.json && \
+    printf '%s\n' \
+      '{' \
+      '  "name": "@craft-agent/craft-cli",' \
+      '  "version": "0.10.2",' \
+      '  "dependencies": {' \
+      '    "@craft-agent/craft-agents-commands": "workspace:*",' \
+      '    "@craft-agent/shared": "workspace:*"' \
+      '  },' \
+      '  "devDependencies": {' \
+      '    "@types/bun": "latest",' \
+      '    "@types/node": "^25.0.8"' \
+      '  }' \
+      '}' > packages/craft-cli/package.json && \
+    printf '%s\n' \
+      '{' \
+      '  "name": "@craft-agent/marketing",' \
+      '  "version": "0.10.2",' \
+      '  "dependencies": {' \
+      '    "@craft-agent/ui": "workspace:*",' \
+      '    "@paper-design/shaders-react": "^0.0.70",' \
+      '    "react": "^18.3.1",' \
+      '    "react-dom": "^18.3.1",' \
+      '    "react-router-dom": "^7.13.0",' \
+      '    "shiki": "^3.21.0",' \
+      '    "three": "^0.170.0"' \
+      '  },' \
+      '  "devDependencies": {' \
+      '    "@tailwindcss/vite": "^4.1.18",' \
+      '    "@types/react": "^18.3.0",' \
+      '    "@types/react-dom": "^18.3.0",' \
